{
    "name": "alex/php_2026",
    "type": "library",
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Test\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "squizlabs/php_codesniffer": "^4.0",
        "phpstan/phpstan": "^2.1",
        "overtrue/phplint": "^9.7"
    },
    "scripts": {
        "lint": "phplint",
        "cs-check": "phpcs src",
        "cs-fix": "phpcbf src",
        "phpstan": "phpstan analyse src --level=max",
        "test": "phpunit --colors=always",
        "test-coverage": "phpunit --colors=always --coverage-text"
    },
    "require": {
        "php-amqplib/php-amqplib": "^3.7",
        "slim/slim": "^4.15",
        "slim/psr7": "^1.8",
        "webmozart/assert": "^2.4"
    }
}
